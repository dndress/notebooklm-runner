            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Transcript Text": {
      "main": [
        [
          {
            "node": "AI Agent: Storyboard",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gemini 2.5 Flash": {
      "ai_languageModel": [
        [
          {
            "node": "AI Agent: Storyboard",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "AI Agent: Storyboard": {
      "main": [
        [
          {
            "node": "Code: stash storyboard",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Code: stash storyboard": {
      "main": [
